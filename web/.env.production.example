# Variables à définir sur Vercel (Project Settings → Environment Variables).
# API_URL est lue côté serveur (SSR) ; ne pas préfixer NEXT_PUBLIC_.

# URL de l'API Laravel déployée
API_URL=https://api.votre-domaine/api

# URL publique du site (liens canoniques, sitemap, RSS)
NEXT_PUBLIC_SITE_URL=https://votre-domaine
